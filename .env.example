# Copy to .env and adjust. Makefile does this automatically on first `make up`.

# Symfony
APP_ENV=dev
APP_SECRET=change-me-to-a-32-char-random-string

# Database (points to postgres service inside compose network)
DATABASE_URL=postgresql://app:app@postgres:5432/training_tracker?serverVersion=16&charset=utf8

# Redis
REDIS_URL=redis://redis:6379

# Shared secret between Symfony <-> sidecar (HMAC signing of ingest payloads)
SIDECAR_SHARED_SECRET=change-me-to-a-random-string

# Garmin Connect credentials (used by sidecar only; leave blank until Fase 3)
# MFA handling: set GARMIN_MFA=manual to pause on first login; python-garminconnect
# caches the session afterwards.
GARMIN_EMAIL=
GARMIN_PASSWORD=
GARMIN_MFA=manual
